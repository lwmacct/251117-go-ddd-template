# ===================================================
# 生产环境配置文件示例
# ===================================================
# 使用方法：
#   1. 复制此文件：cp .env.example .env
#   2. 修改以下配置项的值
#   3. 启动服务：docker-compose up -d
#
# 安全提示：
#   - .env 文件包含敏感信息，已在 .gitignore 中排除
#   - 不要将 .env 文件提交到版本控制系统
#   - 生产环境使用强随机密码
# ===================================================

# ==================== 应用配置 ====================

# 应用端口（宿主机映射端口）
APP_PORT=8080

# Docker 镜像配置
GITHUB_USERNAME=your-github-username
PROJECT_NAME=go-ddd-template
VERSION=latest

# ==================== 数据库配置 ====================

# PostgreSQL 配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE  # ⚠️ 必须修改
POSTGRES_DB=myapp

# ==================== Redis 配置 ====================

# Redis 密码（可选，留空表示不使用密码）
REDIS_PASSWORD=

# ==================== JWT 配置 ====================

# JWT 签名密钥（⚠️ 生产环境必须使用至少 32 字符的强随机字符串）
# 生成方法：openssl rand -base64 32
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING_AT_LEAST_32_CHARS

# ==================== 认证配置 ====================

# 开发模式密钥（用于验证码开发模式）
# 生成方法：openssl rand -hex 16
DEV_SECRET=CHANGE_ME_TO_RANDOM_HEX_STRING

# 2FA TOTP 发行者名称（显示在用户的验证器应用中）
TWOFA_ISSUER=Go-DDD-Template

# 是否需要验证码（true 或 false）
CAPTCHA_REQUIRED=true

# ===================================================
# 可选配置（已在 config.yaml 中设置默认值，通常不需要修改）
# ===================================================

# 取消注释以下行来覆盖默认配置

# ==================== 服务器配置 ====================
# APP_SERVER_ADDR=0.0.0.0:8080
# APP_SERVER_ENV=production
# APP_SERVER_STATIC_DIR=/apps/data/public/web
# APP_SERVER_DOCS_DIR=/apps/data/public/docs

# ==================== 数据源配置 ====================
# APP_DATA_REDIS_KEY_PREFIX=myapp:
# APP_DATA_AUTO_MIGRATE=false

# ==================== JWT 配置 ====================
# APP_JWT_ACCESS_TOKEN_EXPIRY=15m
# APP_JWT_REFRESH_TOKEN_EXPIRY=168h

# ==================== 认证配置 ====================
# APP_AUTH_DEV_SECRET=dev-secret-change-me
# APP_AUTH_TWOFA_ISSUER=Go-DDD-Template
# APP_AUTH_CAPTCHA_REQUIRED=true

# ===================================================
# 密钥生成命令参考
# ===================================================
#
# 生成 JWT_SECRET (base64 编码):
#   openssl rand -base64 32
#
# 生成 DEV_SECRET (hex 编码):
#   openssl rand -hex 16
#
# 生成 POSTGRES_PASSWORD (强密码):
#   openssl rand -base64 24
#
# ===================================================
